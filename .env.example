# Required in production
ADMIN_TOKEN=
TOKEN_SECRET=
SERVICE_PRIVATE_KEY=
SERVICE_NSEC=
NEXT_PUBLIC_SITE_URL=https://zap-battle.vercel.app

# Nostr session/profile/receipt relays
NOSTR_SESSION_RELAYS=wss://yabu.me,wss://relay.primal.net,wss://relay.damus.io,wss://nos.lol
NEXT_PUBLIC_NOSTR_SESSION_RELAYS=wss://yabu.me,wss://relay.primal.net,wss://relay.damus.io,wss://nos.lol

# Smaller relay list for Zap request tags to keep LNURL QR density lower
ZAP_REQUEST_RELAYS=wss://yabu.me,wss://relay.primal.net,wss://nos.lol
NEXT_PUBLIC_ZAP_REQUEST_RELAYS=wss://yabu.me,wss://relay.primal.net,wss://nos.lol

# Optional production hardening
ALLOWED_ORIGINS=https://example.com

# Development only. Leave unset in production unless explicitly needed.
NEXT_PUBLIC_ENABLE_DEMO_ZAPS=
